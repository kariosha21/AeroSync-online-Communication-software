    } catch (err) {
      showToast('Connection error. Please try again.', false);
    }
  });

  // Helper to generate UUID v4
  function generateUUID() {
    if (crypto && crypto.randomUUID) {
      return crypto.randomUUID();
    }
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  // Create Room handler
  createRoomForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const roomId = generateUUID();
    const password = document.getElementById('create-room-key').value;
    
    if (!password) {
      showToast('Please enter an encryption password', false);
      return;
    }

    // Redirect using URL hash (never sent to backend)
    window.location.href = `room.html#room=${roomId}&key=${encodeURIComponent(password)}`;
  });

  // Join Room handler
  joinRoomForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const roomId = document.getElementById('join-room-id').value.trim();
    const password = document.getElementById('join-room-key').value;

    if (!roomId) {
      showToast('Please enter a valid Room ID', false);
      return;
    }
    if (!password) {
      showToast('Please enter the room encryption password', false);
      return;
    }

    window.location.href = `room.html#room=${roomId}&key=${encodeURIComponent(password)}`;
  });

  checkAuth();
});
